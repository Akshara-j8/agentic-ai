# OpenRouter API
OPENROUTER_API_KEY=

# Optional overrides (these mirror config/settings.py defaults)
DEFAULT_MODEL=openai/gpt-4o-mini
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_TOKENS=4096

# LangGraph limits
RECURSION_LIMIT=25
MAX_ITERATIONS=10
STEP_LIMIT=50

# Guardrails
HUMAN_APPROVAL_REQUIRED=true
ENABLE_GUARDRAILS=true

# Database / audit
DATABASE_PATH=./data/techvest.db
AUDIT_LOG_PATH=./data/audit.log

